{
	"name": "@mem-cash/core",
	"version": "0.0.2",
	"description": "Node engine, subscription manager, and mempool acceptance for mem-cash",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mainnet-pat/mem-cash.git",
		"directory": "packages/core"
	},
	"keywords": [
		"bitcoin-cash",
		"electrum",
		"node",
		"subscriptions",
		"mempool"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"prepublishOnly": "tsc -b"
	},
	"dependencies": {
		"@bitauth/libauth": "^3.1.0-next.8",
		"@mem-cash/storage": "0.0.2",
		"@mem-cash/types": "0.0.2"
	},
	"peerDependencies": {
		"@mem-cash/validation": "0.0.2"
	},
	"peerDependenciesMeta": {
		"@mem-cash/validation": {
			"optional": true
		}
	}
}
