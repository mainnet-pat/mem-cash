{
	"name": "@mem-cash/electrum",
	"version": "0.0.4",
	"description": "Fulcrum-compatible Electrum Cash protocol handlers and dispatch for mem-cash",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mainnet-pat/mem-cash.git",
		"directory": "packages/electrum"
	},
	"keywords": [
		"bitcoin-cash",
		"electrum",
		"fulcrum",
		"rpc",
		"protocol"
	],
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"prepublishOnly": "tsc -b"
	},
	"dependencies": {
		"@bitauth/libauth": "^3.1.0-next.8",
		"@mem-cash/core": "0.0.4",
		"@mem-cash/storage": "0.0.4",
		"@mem-cash/types": "0.0.4"
	},
	"peerDependencies": {
		"@mem-cash/validation": "0.0.4"
	},
	"peerDependenciesMeta": {
		"@mem-cash/validation": {
			"optional": true
		}
	}
}
