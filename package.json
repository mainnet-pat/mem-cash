{
	"private": true,
	"description": "Electrum Cash protocol implementation in modern, tree-shakeable TypeScript",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mainnet-pat/mem-cash.git"
	},
	"engines": {
		"node": ">=20"
	},
	"workspaces": ["packages/*"],
	"scripts": {
		"build": "tsc -b",
		"typecheck": "tsc -b --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"biome": "biome check --write",
		"lint": "biome lint",
		"format": "biome format --write",
		"bump": "node bump.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.15",
		"@types/node": "^25.2.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
